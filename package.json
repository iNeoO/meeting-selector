{
  "name": "meeting-selector",
  "version": "1.0.1",
  "description": "Monorepo for meeting-selector components",
  "scripts": {
    "dev:vue-meeting-selector": "pnpm --filter vue-meeting-selector dev & pnpm --filter vue-meeting-selector-dev dev ",
    "dev:react-meeting-selector": "pnpm --filter react-meeting-selector dev & pnpm --filter react-meeting-selector-dev dev",
    "build:vue-meeting-selector": "pnpm --filter vue-meeting-selector build",
    "build:vue-meeting-selector-dev": "pnpm --filter vue-meeting-selector-dev build",
    "build:react-meeting-selector": "pnpm --filter react-meeting-selector build",
    "build:react-meeting-selector-dev": "pnpm --filter react-meeting-selector-dev build",
    "dev:docs": "pnpm --filter doc-meeting-selector dev",
    "build:docs": "pnpm --filter doc-meeting-selector build",
    "build": "pnpm run build:vue-meeting-selector && pnpm run build:react-meeting-selector && pnpm run build:docs && pnpm run build:vue-meeting-selector-dev && pnpm run build:react-meeting-selector-dev",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test",
    "coverage": "pnpm -r run coverage"
  },
  "keywords": [],
  "author": "pique.valere@gmx.fr",
  "license": "MIT",
  "packageManager": "pnpm@10.13.1",
  "pnpm": {
    "overrides": {
      "js-yaml": "^4.2.0",
      "esbuild": "^0.28.1",
      "flat-cache>flatted": "^3.4.2",
      "eslint>ajv": "^6.14.0",
      "sass-embedded>immutable": "^5.1.5",
      "eslint>minimatch": "^3.1.4",
      "@microsoft/api-extractor>minimatch": "^3.1.4",
      "@microsoft/api-extractor>lodash": "^4.18.0",
      "@microsoft/tsdoc-config>ajv": "^8.18.0",
      "@rushstack/node-core-library>ajv": "^8.18.0",
      "editorconfig>minimatch": "^9.0.7",
      "@vue/language-core>minimatch": "^9.0.7",
      "@typescript-eslint/typescript-estree>minimatch": "^9.0.7",
      "@testing-library/jest-dom>lodash": "^4.18.0",
      "micromatch>picomatch": "^2.3.2",
      "anymatch>picomatch": "^2.3.2",
      "readdirp>picomatch": "^2.3.2",
      "@rollup/pluginutils>picomatch": "^4.0.4",
      "vitepress>vite": "^6.4.3",
      "js-cookie": "^3.0.7"
    }
  }
}
